# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# OAuth/SSO (Authelia/Authentik)
OAUTH_ENABLED=false
OAUTH_CLIENT_ID=apseline
OAUTH_CLIENT_SECRET=your-secret-here
OAUTH_ISSUER_URL=https://auth.yourdomain.com
OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback
OAUTH_SCOPE=openid profile email

# Kubernetes
KUBE_CONFIG_PATH=

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock

# VictoriaMetrics (single TSDB on phis4, the perihelion baremetal node).
# LAN-internal address — resolved via Pi-hole split-horizon DNS.
VM_URL=http://phis4.perihelion.live:8428

# Cloudflare API token (Zone:Read + Analytics:Read scopes).
CLOUDFLARE_API_TOKEN=

# Future: GCE service-account key (provider currently stubbed)
# GCP_SERVICE_ACCOUNT_KEY=/path/to/key.json

# Session
SESSION_SECRET=random-secret-for-sessions
